# Copy this file to ".env" and fill in your keys. Never commit ".env".
# The scripts auto-load ".env"; real environment variables, if set, take precedence.

# SerpApi (https://serpapi.com/) — Google Trends DEMAND signal. Free tier: 250 searches/mo.
SERPAPI_API_KEY=

# YouTube Data API v3 (Google Cloud Console) — COMPETITION signal. API key, no OAuth.
# Enable "YouTube Data API v3" on a project, then create an API key credential.
YOUTUBE_API_KEY=
